{
  "name": "bunny-deploy",
  "version": "0.0.0-semantically-released",
  "description": "GitHub action for deploying your static app to Bunny CDN 🚀",
  "homepage": "https://github.com/R-J-dev/bunny-deploy#readme",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/R-J-dev/bunny-deploy"
  },
  "bugs": {
    "url": "https://github.com/R-J-dev/bunny-deploy/issues"
  },
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest --no-watch",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "pnpm lint && pnpm format",
    "build": "ncc build src/index.ts --license licenses.txt"
  },
  "keywords": [
    "Bunny",
    "Deploy",
    "CDN",
    "GitHub",
    "Action"
  ],
  "engines": {
    "node": "~24"
  },
  "author": "R-J-dev",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-angular": "20.5.0",
    "@commitlint/format": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vercel/ncc": "0.38.4",
    "commitlint": "20.5.0",
    "conventional-changelog-angular": "8.3.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "express": "5.2.1",
    "fast-check": "4.6.0",
    "fs-extra": "11.3.4",
    "get-port": "7.2.0",
    "globals": "17.4.0",
    "license-checker-rseidelsohn": "4.4.2",
    "nock": "14.0.11",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "got": "14.6.6",
    "modern-async": "2.0.4",
    "p-retry": "7.1.1",
    "zod": "4.3.6"
  }
}
